# ─── AI Content Generator · Backend .env ────────────────────────────────────
# REQUIRED — Get your free Groq API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# AI Model (optional — defaults to llama-3.1-8b-instant)
# GROQ_MODEL=llama-3.1-8b-instant

# Server
PORT=5000
NODE_ENV=development

# MongoDB (optional — comment out to disable history)
# MONGO_URI=mongodb://localhost:27017/ai-content-generator
